# Ollama configuration for PageIndexJ
# Copy this to .env to use a local Ollama model instead of OpenAI
#
# 1. Make sure Ollama is running:  ollama serve
# 2. Make sure the model is pulled: ollama pull qwen2.5
# 3. Copy: copy .env.ollama .env   (Windows)  OR  cp .env.ollama .env  (Linux/Mac)
# 4. Run: java -jar target/pageindexj-1.0.0-jar-with-dependencies.jar --pdf_path yourfile.pdf --model qwen2.5

LLM_BASE_URL=http://localhost:11434/v1/chat/completions

# CHATGPT_API_KEY is not needed for Ollama — leave it blank or omit it entirely
# CHATGPT_API_KEY=
